# Copy to .env and fill in. .env must be gitignored.

# --- Hugging Face (only needed when populating the RunPod Network Volume) ---
HF_TOKEN=

# --- GitHub Container Registry ---
GHCR_USER=itrcz
GHCR_PAT=                 # classic PAT with write:packages + read:packages
IMAGE_TAG=v0.1.0
LTX2_REF=main             # LTX-2 repo branch/tag/commit pinned into the image

# --- RunPod ---
RUNPOD_API_KEY=

# --- S3 (worker runtime — passed as RunPod endpoint env vars) ---
S3_ENDPOINT_URL=          # leave empty for AWS; set for R2/B2/etc
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PRESIGN_TTL=3600
