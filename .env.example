# Copy to .env and fill in. .env must be gitignored.

# --- Hugging Face (only needed when populating the RunPod Network Volume) ---
HF_TOKEN=

# --- GitHub Container Registry ---
GHCR_USER=itrcz
GHCR_PAT=                 # classic PAT with write:packages + read:packages
IMAGE_TAG=v0.1.0
LTX2_REF=main             # LTX-2 repo branch/tag/commit pinned into the image

# --- RunPod ---
RUNPOD_API_KEY=

# --- S3 (worker runtime — passed as both RunPod template env and Vast template env) ---
S3_ENDPOINT_URL=          # leave empty for AWS; set for R2/B2/Yandex/etc
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PRESIGN_TTL=3600          # sync /run presign TTL (sec)
ASYNC_PRESIGN_TTL=86400   # async result_url TTL (sec, default 24h)

# --- Vast.ai (parallel deploy) ---
VAST_API_KEY=             # from cloud.vast.ai → Account → API Keys

# --- Registry for the Vast image (reuses GHCR_USER + GHCR_PAT above) ---
# Vast image is pushed to ghcr.io/$GHCR_USER/gr-tv-vst:$IMAGE_TAG.
# Same creds as the RunPod image — no extra setup needed.
# Make sure the GHCR_PAT has `write:packages` scope.
